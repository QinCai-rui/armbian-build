+	phy-names = "dp-phy", "aux-phy";
+	sys = <&vo1>;
+
+	edp_colordepth = <8>; /* 6/8/10/12/16 */
+	edp_color_fmt = <0>;
+	edp_ssc_en = <0>;
+	edp_ssc_mode = <0>;
+
+	edp_lane_rate = <2>;
