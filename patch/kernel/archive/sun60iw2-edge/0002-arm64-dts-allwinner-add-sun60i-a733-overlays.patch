diff --git a/arch/arm64/boot/dts/allwinner/overlay/sun60i-a733-cubie-a7z-reroute-audio-from-hdmi-to-typec-dp.dtso b/arch/arm64/boot/dts/allwinner/overlay/sun60i-a733-cubie-a7z-reroute-audio-from-hdmi-to-typec-dp.dtso
new file mode 100644
index 000000000000..bb8dd4351061
--- /dev/null
+++ b/arch/arm64/boot/dts/allwinner/overlay/sun60i-a733-cubie-a7z-reroute-audio-from-hdmi-to-typec-dp.dtso
@@ -0,0 +1,40 @@
+/dts-v1/;
+/plugin/;
+
+/ {
+	metadata {
+		title = "Reroute audio from HDMI to Type-C DisplayPort";
+		compatible = "radxa,cubie-a7z";
+		category = "misc";
+		exclusive = "i2s3_mach", "i2s3_plat", "i2s3_cpu", "i2s3_codec";
+		description = "Reroute audio from HDMI to Type-C DisplayPort.
+
+Due to the limitation of the platform, the I2S audio codec can only be used by either HDMI or eDP, not both at the same time.
+This is connected to HDMI by default.
+Enable this overlay when playing audio via Type-C DisplayPort.";
+	};
+};
+
+&i2s3_plat {
+	/* av:  */
+	/* av not need dai-type */
+	dai-type;
+	status	= "okay";
+};
+
+&i2s3_mach {
+	soundcard-mach,playback-only;
+	soundcard-mach,name = "allwinner-edp";
+	status = "okay";
+};
+
+&i2s3_cpu {
+	/* av: */
+	soundcard-mach,pll-fs = <4>;
+	soundcard-mach,mclk-fs = <512>;
+};
+
+&i2s3_codec {
+	/* edp: */
+	sound-dai = <&edp0>;
+};
diff --git a/arch/arm64/boot/dts/allwinner/overlay/sun60i-a733-i2s0-2ch.dtso b/arch/arm64/boot/dts/allwinner/overlay/sun60i-a733-i2s0-2ch.dtso
new file mode 100644
index 000000000000..9da8aded4628
--- /dev/null
+++ b/arch/arm64/boot/dts/allwinner/overlay/sun60i-a733-i2s0-2ch.dtso
@@ -0,0 +1,96 @@
+/dts-v1/;
+/plugin/;
+
+/{
+	metadata {
+		title = "Enable I2S0";
+		compatible = "radxa,cubie-a7z", "radxa,cubie-a7s";
+		category = "misc";
+		exclusive = "i2s0_plat", "i2s0_mach", "PB4", "PB5", "PB6", "PB8", "PB7";
+		description = "Enable I2S0 2-channel dummy sound card.
+This overlay is only for demonstration purpose.
+It does not support any specific hardware device.
+On Radxa Cubie A7Z, this is pin_36(mclk), pin_12(bclk), pin_35(lrck), pin_38(din0), pin_40(dout0).
+On Radxa Cubie A7S, this is pin_36(mclk), pin_12(bclk), pin_35(lrck), pin_37(din0), pin_38(dout0).
+";
+	};
+};
+
+&pio {
+	/* i2s0 pins */
+	i2s0_pins_a: i2s0@0 {
+		pins = "PB4";
+		function = "i2s0_mclk";
+		allwinner,drive = <1>;
+		bias-disable;
+	};
+
+	i2s0_pins_b: i2s0@1 {
+		pins = "PB5";
+		function = "i2s0_bclk";
+		allwinner,drive = <1>;
+		bias-disable;
+	};
+
+	i2s0_pins_c: i2s0@2 {
+		pins = "PB6";
+		function = "i2s0_lrck";
+		allwinner,drive = <1>;
+		bias-disable;
+	};
+
+	i2s0_pins_d: i2s0@3 {
+		pins = "PB8";
+		function = "i2s0_din0";
+		allwinner,drive = <1>;
+		bias-pull-down;
+	};
+
+	i2s0_pins_e: i2s0@4 {
+		pins = "PB7";
+		function = "i2s0_dout0";
+		allwinner,drive = <1>;
+		bias-pull-down;
+	};
+
+	i2s0_pins_f: i2s0@5 {
+		pins = "PB4", "PB5", "PB6", "PB8", "PB7";
+		function = "io_disabled";
+		allwinner,drive = <1>;
+		bias-disable;
+	};
+};
+
+&i2s0_plat {
+	tdm-num = <0>;
+	tx-pin = <0>;
+	rx-pin = <0>;
+
+	tx-hub-en;
+	rx-sync-en;
+
+	pinctrl-used;
+	pinctrl-names = "default","sleep";
+	pinctrl-0 = <&i2s0_pins_a &i2s0_pins_b &i2s0_pins_c &i2s0_pins_d &i2s0_pins_e>;
+	pinctrl-1 = <&i2s0_pins_f>;
+
+	status = "okay";
+};
+
+&i2s0_mach {
+	soundcard-mach,format = "i2s";
+	soundcard-mach,frame-master	= <&i2s0_cpu>;
+	soundcard-mach,bitclock-master = <&i2s0_cpu>;
+	/* soundcard-mach,frame-inversion; */
+	/* soundcard-mach,bitclock-inversion; */
+	soundcard-mach,slot-num = <2>;
+	soundcard-mach,slot-width = <32>;
+	status = "okay";
+	i2s0_cpu: soundcard-mach,cpu {
+		sound-dai = <&i2s0_plat>;
+		soundcard-mach,pll-fs	= <1>;
+		soundcard-mach,mclk-fs	= <0>;
+	};
+	i2s0_codec: soundcard-mach,codec {
+	};
+};
