+
+dtb-$(CONFIG_ARCH_SUN60IW2) += \
+	sun60i-a733-i2s0-2ch.dtbo \
+	sun60i-a733-i2s4-2ch.dtbo \
+	sun60i-a733-pwm1-1.dtbo \
+	sun60i-a733-pwm1-2.dtbo \
+	sun60i-a733-pwm1-3.dtbo \
+	sun60i-a733-pwm1-6.dtbo \
+	sun60i-a733-pwm1-7.dtbo \
+	sun60i-a733-spi1-spidev.dtbo \
+	sun60i-a733-spi3-spidev.dtbo \
+	sun60i-a733-twi2.dtbo \
+	sun60i-a733-twi7.dtbo \
+	sun60i-a733-uart2.dtbo \
+	sun60i-a733-uart3.dtbo \
+	sun60i-a733-uart4.dtbo \
+	sun60i-a733-cubie-a7a-enable-sunxi-ac101-sound-card.dtbo \
+	sun60i-a733-cubie-a7a-radxa-25w-poe.dtbo \
+	sun60i-a733-cubie-a7a-radxa-camera-8m-219.dtbo \
+	sun60i-a733-cubie-a7a-radxa-camera-13m-214.dtbo \
+	sun60i-a733-cubie-a7a-radxa-camera-4k-415.dtbo \
+	sun60i-a733-cubie-a7a-radxa-display-8hd.dtbo \
+	sun60i-a733-cubie-a7a-radxa-display-10fhd.dtbo \
+	sun60i-a733-cubie-a7z-reroute-audio-from-hdmi-to-typec-dp.dtbo
