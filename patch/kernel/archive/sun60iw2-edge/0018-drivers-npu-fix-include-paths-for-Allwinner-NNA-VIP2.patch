From f1ceafd64e59e2a2eb855e183306f07ae07d6d13 Mon Sep 17 00:00:00 2001
From: Nick Alilovic <nickalilovic@gmail.com>
Date: Mon, 23 Mar 2026 22:13:52 -0400
Subject: [PATCH] drivers: npu: fix include paths for Allwinner NNA VIP2

Updated Kbuild to use ccflags-y instead of deprecated EXTRA_CFLAGS
to ensure compatibility with the 6.18 kernel build system.

Removed $(srctree) prefixes from include paths to allow the compiler
to correctly resolve headers within the custom bsp/ directory
structure, fixing fatal errors during the compilation of
vip_drv_interface.c.

---
 bsp/drivers/npu/aw_nna_vip/vip2/Kbuild | 96 +++++++++++++++---------------
 1 file changed, 47 insertions(+), 48 deletions(-)

diff --git a/bsp/drivers/npu/aw_nna_vip/vip2/Kbuild b/bsp/drivers/npu/aw_nna_vip/vip2/Kbuild
index 25b31f29..a12aef9c 100755
--- a/bsp/drivers/npu/aw_nna_vip/vip2/Kbuild
+++ b/bsp/drivers/npu/aw_nna_vip/vip2/Kbuild
@@ -10,14 +10,13 @@ export AUTO_CORRECT_CONFLICTS=1
 export PLATFORM_NAME=allwinner
 
 
-EXTRA_CFLAGS += -Werror -Wno-unused-function
-EXTRA_CFLAGS += -I$(srctree)/$(src) \
-				-I$(srctree)/$(src)/inc \
-				-I$(srctree)/$(src)/memory \
-				-I$(srctree)/$(src)/os/linux \
-				-I$(srctree)/$(src)/os/linux/allocator \
-				-I$(srctree)/$(src)/os/linux/platform/$(PLATFORM_NAME) \
-				-I$(srctree)/$(src)/task
+ccflags-y += -I$(src) \
+				-I$(src)/inc \
+				-I$(src)/memory \
+				-I$(src)/os/linux \
+				-I$(src)/os/linux/allocator \
+				-I$(src)/os/linux/platform/$(PLATFORM_NAME) \
+				-I$(src)/task
 
 OBJS := vip_drv_interface.o \
         vip_drv_hardware.o \
@@ -63,10 +63,10 @@ endif
 
 
 #Include platform config if exists.
--include $(srctree)/$(src)/os/linux/platform/$(PLATFORM_NAME)/platform.mk
+-include $(src)/os/linux/platform/$(PLATFORM_NAME)/platform.mk
 
 ifneq ($(CONFIG_NPU_USER_IOMMU), )
-	OBJS += $(srctree)/$(src)/os/linux/platform/$(PLATFORM_NAME)/gc_vip_kernel_ion.o
+	OBJS += $(src)/os/linux/platform/$(PLATFORM_NAME)/gc_vip_kernel_ion.o
 endif
 
 #NOTE:
@@ -93,149 +93,149 @@ install: all
 	@cp $(MODULE_NAME).ko $(SDK_DIR)/drivers
 
 
-EXTRA_CFLAGS += -DLINUX -DDRIVER
+ccflags-y += -DLINUX -DDRIVER
 
 # NPU USE IOMMU
 ifneq ($(CONFIG_NPU_USER_IOMMU), )
-EXTRA_CFLAGS += -DNPU_USER_IOMMU=0
+ccflags-y += -DNPU_USER_IOMMU=0
 else
-EXTRA_CFLAGS += -DNPU_USER_IOMMU=1
+ccflags-y += -DNPU_USER_IOMMU=1
 endif
 
 ifeq ($(FLAREON),1)
-EXTRA_CFLAGS += -DFLAREON
+ccflags-y += -DFLAREON
 endif
 
 ifeq ($(DEBUG), 1)
-EXTRA_CFLAGS += -DDBG=1 -DDEBUG -D_DEBUG -DvpmdENABLE_DEBUG_LOG=4
+ccflags-y += -DDBG=1 -DDEBUG -D_DEBUG -DvpmdENABLE_DEBUG_LOG=4
 else
-EXTRA_CFLAGS += -DDBG=0
+ccflags-y += -DDBG=0
 endif
 
-EXTRA_CFLAGS += -DUSE_LINUX_PLATFORM_DEVICE
+ccflags-y += -DUSE_LINUX_PLATFORM_DEVICE
 
 ifneq ($(FPGA_BUILD), )
-EXTRA_CFLAGS += -DvpmdFPGA_BUILD=$(FPGA_BUILD)
+ccflags-y += -DvpmdFPGA_BUILD=$(FPGA_BUILD)
 endif
 
 ifeq ($(USE_LINUX_CMA), 1)
-EXTRA_CFLAGS += -DUSE_LINUX_CMA
+ccflags-y += -DUSE_LINUX_CMA
 endif
 
 ifeq ($(USE_LINUX_MEM_ION), 1)
-EXTRA_CFLAGS += -DUSE_LINUX_MEM_ION
+ccflags-y += -DUSE_LINUX_MEM_ION
 endif
 
 ifneq ($(USE_AGENT), )
-EXTRA_CFLAGS += -DvpmdENABLE_USE_AGENT_TRIGGER=$(USE_AGENT)
+ccflags-y += -DvpmdENABLE_USE_AGENT_TRIGGER=$(USE_AGENT)
 endif
 
 
 ifneq ($(CONFIG_NPU_USER_IOMMU), )
 	ifneq ($(ENABLE_MMU), )
-	EXTRA_CFLAGS += -DvpmdENABLE_MMU=$(ENABLE_MMU)
+	ccflags-y += -DvpmdENABLE_MMU=$(ENABLE_MMU)
 	endif
 else
 	ifeq ($(DISABLE_MMU), 1)
-	EXTRA_CFLAGS += -DvpmdENABLE_MMU=0
+	ccflags-y += -DvpmdENABLE_MMU=0
 	endif
 endif
 
 ifneq ($(ENABLE_40BITVA), )
-EXTRA_CFLAGS += -DvpmdENABLE_40BITVA=$(ENABLE_40BITVA)
+ccflags-y += -DvpmdENABLE_40BITVA=$(ENABLE_40BITVA)
 endif
 
 ifeq ($(DISABLE_CREATE_BUF_FD),1)
-EXTRA_CFLAGS += -DvpmdENABLE_CREATE_BUF_FD=0
+ccflags-y += -DvpmdENABLE_CREATE_BUF_FD=0
 endif
 
 ifneq ($(ENABLE_SYS_MEMORY_HEAP), )
-EXTRA_CFLAGS += -DvpmdENABLE_SYS_MEMORY_HEAP=$(ENABLE_SYS_MEMORY_HEAP)
+ccflags-y += -DvpmdENABLE_SYS_MEMORY_HEAP=$(ENABLE_SYS_MEMORY_HEAP)
 endif
 
 ifneq ($(ENABLE_VIDEO_MEMORY_HEAP), )
-EXTRA_CFLAGS += -DvpmdENABLE_VIDEO_MEMORY_HEAP=$(ENABLE_VIDEO_MEMORY_HEAP)
+ccflags-y += -DvpmdENABLE_VIDEO_MEMORY_HEAP=$(ENABLE_VIDEO_MEMORY_HEAP)
 endif
 
 ifneq ($(ENABLE_VIDEO_MEMORY_DYNAMIC), )
-EXTRA_CFLAGS += -DvpmdENABLE_VIDEO_MEMORY_DYNAMIC=$(ENABLE_VIDEO_MEMORY_DYNAMIC)
+ccflags-y += -DvpmdENABLE_VIDEO_MEMORY_DYNAMIC=$(ENABLE_VIDEO_MEMORY_DYNAMIC)
 endif
 
 ifneq ($(POWER_OFF_TIMEOUT), )
-EXTRA_CFLAGS += -DvpmdPOWER_OFF_TIMEOUT=$(POWER_OFF_TIMEOUT)
+ccflags-y += -DvpmdPOWER_OFF_TIMEOUT=$(POWER_OFF_TIMEOUT)
 endif
 
 ifneq ($(HARDWARE_RECOVERY), )
-EXTRA_CFLAGS += -DvpmdENABLE_RECOVERY=$(HARDWARE_RECOVERY)
+ccflags-y += -DvpmdENABLE_RECOVERY=$(HARDWARE_RECOVERY)
 endif
 
 ifneq ($(NODE_MEMORY_IN_HEAP), )
-EXTRA_CFLAGS += -DvpmdNODE_MEMORY_IN_HEAP=$(NODE_MEMORY_IN_HEAP)
+ccflags-y += -DvpmdNODE_MEMORY_IN_HEAP=$(NODE_MEMORY_IN_HEAP)
 endif
 
 ifneq ($(AUTO_CORRECT_CONFLICTS), )
-EXTRA_CFLAGS += -DvpmdAUTO_CORRECT_CONFLICTS=$(AUTO_CORRECT_CONFLICTS)
+ccflags-y += -DvpmdAUTO_CORRECT_CONFLICTS=$(AUTO_CORRECT_CONFLICTS)
 endif
 
 ifneq ($(ENABLE_MULTIPLE_TASK), )
-EXTRA_CFLAGS += -DvpmdENABLE_MULTIPLE_TASK=$(ENABLE_MULTIPLE_TASK)
+ccflags-y += -DvpmdENABLE_MULTIPLE_TASK=$(ENABLE_MULTIPLE_TASK)
 endif
 
 ifneq ($(ENABLE_RESERVE_PHYSICAL), )
-EXTRA_CFLAGS += -DvpmdENABLE_RESERVE_PHYSICAL=$(ENABLE_RESERVE_PHYSICAL)
+ccflags-y += -DvpmdENABLE_RESERVE_PHYSICAL=$(ENABLE_RESERVE_PHYSICAL)
 endif
 
 ifneq ($(LIUNX_USE_MEM_WRITE_COMBINE), )
-EXTRA_CFLAGS += -DLIUNX_USE_MEM_WRITE_COMBINE
+ccflags-y += -DLIUNX_USE_MEM_WRITE_COMBINE
 endif
 
 ifneq ($(ENABLE_SUSPEND_RESUME), )
-EXTRA_CFLAGS += -DvpmdENABLE_SUSPEND_RESUME=$(ENABLE_SUSPEND_RESUME)
+ccflags-y += -DvpmdENABLE_SUSPEND_RESUME=$(ENABLE_SUSPEND_RESUME)
 endif
 
 ifneq ($(ENABLE_REDUCE_MEMORY), )
-EXTRA_CFLAGS += -DvpmdENABLE_REDUCE_MEMORY=$(ENABLE_REDUCE_MEMORY)
+ccflags-y += -DvpmdENABLE_REDUCE_MEMORY=$(ENABLE_REDUCE_MEMORY)
 endif
 
 ifneq ($(ENABLE_POLLING), )
-EXTRA_CFLAGS += -DvpmdENABLE_POLLING=$(ENABLE_POLLING)
+ccflags-y += -DvpmdENABLE_POLLING=$(ENABLE_POLLING)
 endif
 
 ifneq ($(ENABLE_PREEMPTION), )
-EXTRA_CFLAGS += -DvpmdENABLE_PREEMPTION=$(ENABLE_PREEMPTION)
+ccflags-y += -DvpmdENABLE_PREEMPTION=$(ENABLE_PREEMPTION)
 endif
 
 ifneq ($(ENABLE_CHECKSUM), )
-EXTRA_CFLAGS += -DvpmdENABLE_CHECKSUM=$(ENABLE_CHECKSUM)
+ccflags-y += -DvpmdENABLE_CHECKSUM=$(ENABLE_CHECKSUM)
 endif
 
 ifneq ($(HARDWARE_BYPASS_MODE), )
-EXTRA_CFLAGS += -DvpmdHARDWARE_BYPASS_MODE=$(HARDWARE_BYPASS_MODE)
+ccflags-y += -DvpmdHARDWARE_BYPASS_MODE=$(HARDWARE_BYPASS_MODE)
 endif
 
 ifneq ($(PRELOAD_COEFF), )
-EXTRA_CFLAGS += -DvpmdPRELOAD_COEFF=$(PRELOAD_COEFF)
+ccflags-y += -DvpmdPRELOAD_COEFF=$(PRELOAD_COEFF)
 endif
 
 ifneq ($(DUMP_NBG_RESOURCE), )
-EXTRA_CFLAGS += -DvpmdDUMP_NBG_RESOURCE=$(DUMP_NBG_RESOURCE)
+ccflags-y += -DvpmdDUMP_NBG_RESOURCE=$(DUMP_NBG_RESOURCE)
 endif
 
 ifneq ($(ENABLE_FUSA), )
-EXTRA_CFLAGS += -DvpmdENABLE_FUSA=$(ENABLE_FUSA)
+ccflags-y += -DvpmdENABLE_FUSA=$(ENABLE_FUSA)
 OBJS += vip_drv_fusa.o
 endif
 
 ifneq ($(TASK_CMD_DUMP), )
-EXTRA_CFLAGS += -DvpmdTASK_CMD_DUMP=$(TASK_CMD_DUMP)
+ccflags-y += -DvpmdTASK_CMD_DUMP=$(TASK_CMD_DUMP)
 endif
 
 ifneq ($(ENABLE_LAYER_DUMP), )
-EXTRA_CFLAGS += -DvpmdENABLE_LAYER_DUMP=$(ENABLE_LAYER_DUMP)
+ccflags-y += -DvpmdENABLE_LAYER_DUMP=$(ENABLE_LAYER_DUMP)
 endif
 
 ifneq ($(ENABLE_NPD), )
-EXTRA_CFLAGS += -DvpmdENABLE_NPD=$(ENABLE_NPD)
+ccflags-y += -DvpmdENABLE_NPD=$(ENABLE_NPD)
 endif
 
 obj-$(CONFIG_AW_NNA_VIP) = $(MODULE_NAME).o
@@ -244,4 +244,4 @@ $(MODULE_NAME)-objs  = $(OBJS)
 
 
 #only for checking driver build option
--include $(srctree)/$(src)/check.Kbuild
+-include $(src)/check.Kbuild
-- 
2.51.0

